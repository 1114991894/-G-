# 百鲸G系统v9.0环境配置

# 服务器配置
PORT=3000
NODE_ENV=development

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bwg_performance
DB_USER=root
DB_PASS=

# JWT 密钥
JWT_SECRET=bwg_performance_2024_secret_key
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AI 服务配置（OpenRouter）
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 向量数据库配置（Milvus）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Elasticsearch 配置
ES_HOST=http://localhost:9200

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs
